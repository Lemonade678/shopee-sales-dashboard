# Copy this file to .env.local and fill in your Supabase project values.
# The dashboard runs with generated demo data when these are left blank.

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the CSV import API to bypass RLS for bulk inserts.
# NEVER expose this to the client. Keep it out of NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Powers the AI automation team (npm run agents).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
